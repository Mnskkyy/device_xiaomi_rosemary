allow hal_power_default sysfs_touchpanel:dir r_dir_perms;
allow hal_power_default sysfs_touchpanel:file rw_file_perms;

# To do powerhint on nodes defined in powerhint.json
allow hal_power_default vendor_sysfs_gpu:dir search;
allow hal_power_default vendor_sysfs_gpu:file rw_file_perms;

# GED DVFS tuning nodes (dvfs_margin_value, loading_base_dvfs_step)
allow hal_power_default sysfs_ged:dir r_dir_perms;
allow hal_power_default sysfs_ged:file rw_file_perms;

# Scheduler migration cost tuning (SchedMigrationCost node)
allow hal_power_default proc_sched_migration_cost_ns:file rw_file_perms;

# cgroup uclamp writes (UclampFGMin, UclampTAMin, UclampCamMin nodes)
allow hal_power_default cgroup:file rw_file_perms;
